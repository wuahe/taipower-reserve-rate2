PORT=3000
NODE_ENV=development

# Zeabur PostgreSQL usually provides DATABASE_URL from the database service.
# Leave it empty locally to use data/reserve-readings.json.
DATABASE_URL=
DATABASE_SSL=false

# Comma-separated official Taipower URLs. Defaults are set in src/config.ts.
TAIPOWER_SOURCE_URLS=

# Collector interval in milliseconds. 600000 = 10 minutes.
COLLECT_INTERVAL_MS=600000

# File storage path for local development when DATABASE_URL is empty.
DATA_FILE=data/reserve-readings.json
